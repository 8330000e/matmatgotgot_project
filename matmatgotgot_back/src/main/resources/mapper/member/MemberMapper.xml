<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.twotwo.matmatgotgot.domain.member.mapper.MemberMapper">
	<select id="selectAll" resultType="member">
		select * from member_tbl
	</select>
	<insert id="insertMember">
		insert into member_tbl (member_id,member_pw,member_name,member_email,member_nickname) value (#{memberId},#{memberPw},#{memberName},#{memberEmail},#{memberNickname})
	</insert>
	<select id="selectOneMember" resultType="member">
		select * from member_tbl where member_id = #{memberId}
	</select>
	<select id="selectOneMemberByEmail" resultType="member">
		select * from member_tbl where member_email = #{email}
	</select>
	<insert id="googleInsertMember">
		insert into social_login_tbl (social_google) value (CURRENT_TIMESTAMP)
	</insert>
</mapper>
